# Public URL path when hosted under a subdirectory (must end with /).
# Local: leave unset or use /
# Production (S3): /demo/mherman/author/
# VITE_BASE_PATH=/demo/mherman/author/

# Production API routing (S3/CloudFront has no Vite proxy):
# VITE_API_DIRECT=true
# Or point at a shared reverse proxy:
# VITE_API_PROXY_BASE=https://your-proxy.example.com

# Optional default tenant URL shown on the login screen
VITE_DEFAULT_SERVER_URL=https://your-tenant.egain.cloud

# Context root prepended before /ws/... (eGain examples use "system")
VITE_CONTEXT_ROOT=system

# Knowledge Authoring API version (documented v12 paths are rewritten to this)
VITE_API_VERSION=v20

# Department id is loaded from the logged-in user profile
# (departments.department[].id where home=yes) — do not set manually.

# OAuth / Client Application — register as SPA with PKCE in eGain Admin Console
# Partition → Integration → Client Application
VITE_OAUTH_CLIENT_ID=your-client-id
# From client application Metadata (Authorization URL / Token URL)
VITE_OAUTH_AUTH_URL=
VITE_OAUTH_TOKEN_URL=
# Token URL may be /ws/v19/clientapplications/... — keep v19 for OAuth client endpoints
VITE_OAUTH_SCOPES=openid profile
VITE_OAUTH_REDIRECT_URI=http://localhost:5173/oauth/callback
# Production example:
# VITE_OAUTH_REDIRECT_URI=https://aznadestzw4.egdemo.info/demo/mherman/author/oauth/callback

# Set to true to force demo mode (sample data, no remote calls)
VITE_FORCE_DEMO=false
